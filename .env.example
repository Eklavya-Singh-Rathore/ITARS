# ITARS V2 backend configuration (copy to .env and adjust). All optional —
# sensible defaults resolve the existing hf_deploy/ artifacts automatically.

# --- Paths (override only if artifacts live elsewhere) ---
# ITARS_MODEL_DIR=../hf_deploy/Models
# ITARS_DATA_DIR=../hf_deploy/Data
# ITARS_ROUTING_CONFIG=./config/routing_config.yaml

# --- Embedding models (HF Hub repo ids; fine-tuned weights are public) ---
# ITARS_ROUTING_SBERT=Eklavya73/sbert_finetuned
# ITARS_DUPLICATE_SBERT=Eklavya73/duplicate_sbert

# --- Hybrid routing weights ---
# ITARS_HYBRID_CLASSIFIER_WEIGHT=0.7
# ITARS_HYBRID_SIMILARITY_WEIGHT=0.3

# --- Two-stage gate thresholds ---
# ITARS_HYBRID_FLOOR=0.45
# ITARS_FLAGGED_HYBRID_FLOOR=0.30
# ITARS_MARGIN_THRESHOLD=0.15
# ITARS_ENTROPY_THRESHOLD=1.8

# --- Retrieval ---
# ITARS_TOP_TAGS_K=5
# ITARS_DUPLICATE_TOP_K=20

# --- Controlled-review demo cap (parity with deployed Space) ---
# ITARS_APPLY_DEMO_REVIEW_CAP=true
# ITARS_DEMO_REVIEW_THRESHOLD_CAP=0.30

# --- Database (Phase 6 / 15A): SQLite for dev, Postgres / Supabase for prod ---
# Local SQLite (default if unset):
# ITARS_DATABASE_URL=sqlite:///./itars.db
#
# Self-hosted Postgres:
# ITARS_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/itars
#
# Supabase — pick the connection method that fits your deploy target:
#   Direct (IPv6 only; long-lived backend with IPv6 network):
#   ITARS_DATABASE_URL=postgresql+psycopg://postgres:<DB-PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres
#
#   Shared pooler — session mode (IPv4; persistent backends, RECOMMENDED):
#   ITARS_DATABASE_URL=postgresql+psycopg://postgres.<PROJECT-REF>:<DB-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
#
#   Shared pooler — transaction mode (IPv4; serverless / edge functions):
#   ITARS_DATABASE_URL=postgresql+psycopg://postgres.<PROJECT-REF>:<DB-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# The driver scheme is auto-normalized — bare `postgres://` / `postgresql://`
# URLs are also accepted. The Supabase transaction-mode pooler is detected and
# wired up with NullPool + no prepared statements automatically.

# --- Deployment / security (Phase 14) ---
# Lock CORS to the deployed frontend origin(s) in production (comma-separated).
# ITARS_CORS_ORIGINS=https://itars.vercel.app
# Optional shared API token; when set, every non-public endpoint requires it
# (sent as X-API-Key or Authorization: Bearer). /health and /docs stay open.
# ITARS_API_TOKEN=

# --- LLM gateway (Phase 8): provider-agnostic; defaults to offline 'echo' ---
# ITARS_LLM_PROVIDER=echo                    # echo | gemini | grok
# ITARS_LLM_FALLBACK=echo                    # comma-separated fallback order
# GEMINI_API_KEY=
# ITARS_GEMINI_MODEL=gemini-2.5-flash
# GROK_API_KEY=                              # or XAI_API_KEY
# ITARS_GROK_MODEL=grok-3-mini
# ITARS_LLM_MAX_OUTPUT_TOKENS=512
# ITARS_LLM_TEMPERATURE=0.3
# ITARS_LLM_FEATURE_TOKEN_BUDGET=200000      # 0 = unlimited

# --- RAG (Phase 7 / 15B): retrieval-only; routing stays on all-mpnet+FAISS ---
# ITARS_RAG_ENABLED=true
#
# Qdrant URL — pick one:
#   :memory:                                       (dev / tests, ephemeral)
#   https://<cluster>.cloud.qdrant.io:6333         (Qdrant Cloud — recommended)
#   http://localhost:6333                          (self-host via docker-compose)
#   ./qdrant_data                                  (embedded, on-disk)
# Bare hosts (e.g. `xyz.cloud.qdrant.io`) get auto-prefixed with https://.
# ITARS_QDRANT_URL=:memory:
# ITARS_QDRANT_API_KEY=                           (required for Qdrant Cloud)
#
# ITARS_RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# ITARS_RAG_EMBEDDING_DIM=384
# ITARS_RAG_TOP_K=5
# ITARS_RAG_SCORE_FLOOR=0.5                       # below this cosine, "no similar found"

# --- Translation (Phase 3) ---
# ITARS_TRANSLATION_ENABLED=true
# ITARS_TRANSLATION_MODEL_DE=Helsinki-NLP/opus-mt-de-en
# ITARS_TRANSLATION_MODEL_ROMANCE=Helsinki-NLP/opus-mt-ROMANCE-en
# ITARS_TRANSLATION_MAX_WORDS=400
# ITARS_TRANSLATION_MAX_LENGTH=512
# ITARS_TRANSLATION_CACHE_SIZE=1024

# --- Optional: HF token if you re-enable Hub-only asset loading ---
# HF_TOKEN=
